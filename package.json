{
  "name": "chromacraft-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "prisma:migrate": "npm --workspace packages/db run prisma:migrate",
    "prisma:generate": "npm --workspace packages/db run prisma:generate"
  }
}
