generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  PROCESSING
  QA_PENDING
  COMPLETED
  FAILED
}

enum IterationStatus {
  RUNNING
  PASSED
  FAILED
  RETRYING
}

enum JobType {
  CATALOG_VARIANTS
  LIFESTYLE_SCENES
}

enum Role {
  ADMIN
  USER
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  passwordHash  String?
  name          String?
  emailVerified DateTime?
  image         String?
  role          Role            @default(USER)
  twoFactorEnabled Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  jobs          Job[]
  passwordResets PasswordReset[]
  accounts      Account[]
  sessions      Session[]
}

model Job {
  id             Int               @id @default(autoincrement())
  name           String
  jobType        JobType           @default(CATALOG_VARIANTS)
  status         JobStatus         @default(PENDING)
  currentGoal    String?
  statusHistory  Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userId         Int
  user           User              @relation(fields: [userId], references: [id])
  assets         Asset[]
  iterations     Iteration[]
  promptId       Int?              @unique
  prompt         PromptTemplate?   @relation(fields: [promptId], references: [id])
  generation     Generation?
  providerId     Int?
  provider       AiProvider?       @relation(fields: [providerId], references: [id])
}

model Asset {
  id        Int      @id @default(autoincrement())
  type      String   // e.g., "original", "variant", "processed"
  path      String
  status    String   // e.g., "pending", "done", "error"
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id])
}

model PromptTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  job       Job?
}

model Generation {
  id       Int      @id @default(autoincrement())
  metadata Json?
  jobId    Int      @unique
  job      Job      @relation(fields: [jobId], references: [id])
}

model Iteration {
  id         Int             @id @default(autoincrement())
  jobId      Int
  job        Job             @relation(fields: [jobId], references: [id])
  prompt     String
  critique   String?
  status     IterationStatus @default(RUNNING)
  assetPath  String?
  createdAt  DateTime        @default(now())
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model AiProvider {
  id      Int    @id @default(autoincrement())
  name    String @unique
  apiKey  String
  default Boolean @default(false)
  jobs    Job[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             Int
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
