{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
